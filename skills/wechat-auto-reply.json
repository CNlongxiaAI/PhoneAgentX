{
  "name": "wechat-auto-reply",
  "display_name": "微信托管自动回复",
  "display_name_en": "WeChat Auto Reply",
  "version": "1.0.0",
  "author": "agentclaw-official",
  "description": "托管微信消息，AI自动回复所有新消息，支持自定义托管时长和AI角色",
  "description_en": "Auto-reply to all WeChat messages with customizable AI persona",
  "icon": "message-circle",
  "category": "social",
  "tags": ["微信", "自动回复", "托管", "AI助手"],
  "estimated_time": "30m",
  "estimated_tokens": 5000,
  "requires": { "apps": ["com.tencent.mm"] },
  "config": {},
  "steps": [
    {
      "id": "ask_settings",
      "type": "prompt_user",
      "title": "微信托管设置",
      "fields": [
        {
          "key": "duration",
          "label": "托管时长（分钟）",
          "type": "select",
          "options": ["5", "10", "15", "30", "60"],
          "default": "30"
        },
        {
          "key": "role",
          "label": "AI回复角色",
          "type": "select",
          "options": ["专业秘书", "幽默朋友", "简洁助手", "模仿本人"],
          "default": "专业秘书"
        }
      ],
      "timeout": 60,
      "timeout_action": "use_default"
    },
    {
      "id": "open_wechat",
      "type": "api",
      "action": "open_app",
      "params": { "app_name": "com.tencent.mm" }
    },
    {
      "id": "wait_wechat_load",
      "type": "wait_until_changed",
      "timeout": 5000,
      "stable_ms": 1000
    },
    {
      "id": "check_wechat_state",
      "type": "ai_check",
      "prompt": "观察当前微信界面，判断状态：\n- 如果已经在微信主界面（能看到底部Tab），没有弹窗遮挡，回复包含「正常」\n- 如果有弹窗或不在微信主界面，回复包含「异常」",
      "branches": [
        { "match": "正常", "label": "微信主界面", "goto": "subscribe" },
        { "match": "异常", "label": "需要处理", "goto": "handle_wechat_popup" }
      ],
      "default_branch": { "goto": "subscribe", "label": "默认继续" }
    },
    {
      "id": "handle_wechat_popup",
      "type": "ai_act",
      "prompt": "当前微信界面有弹窗或不在主界面，请处理：\n1. 关闭所有弹窗\n2. 如果不在微信主界面，点击底部「微信」Tab",
      "max_loops": 3
    },
    {
      "id": "subscribe",
      "type": "api",
      "action": "subscribe_events",
      "params": { "package": "com.tencent.mm" }
    },
    {
      "id": "go_home",
      "type": "api",
      "action": "press_home"
    },
    {
      "id": "auto_reply_loop",
      "type": "loop",
      "label": "微信托管中",
      "max_duration": 3600000,
      "max_iterations": 200,
      "loop_steps": [
        {
          "id": "wait_notification",
          "type": "wait_for_event",
          "event_types": ["notification_state_changed"],
          "timeout": 120000,
          "save_as": "notify"
        },
        {
          "id": "open_wechat_for_reply",
          "type": "api",
          "action": "open_app",
          "params": { "app_name": "com.tencent.mm" }
        },
        {
          "id": "wait_wechat_ready",
          "type": "wait_until_changed",
          "timeout": 3000,
          "stable_ms": 500
        },
        {
          "id": "reply_message",
          "type": "ai_act",
          "prompt": "你扮演「${input.role}」角色，帮我回复微信新消息。\n通知内容：${notify.text}\n\n步骤：\n1. 在聊天列表中找到联系人click进入\n2. 阅读对方最新消息\n3. click底部输入框激活\n4. type输入回复内容\n5. click发送按钮\n6. 确认发送成功后finished",
          "max_loops": 8
        },
        {
          "id": "count_reply",
          "type": "set_var",
          "var": "_reply_count",
          "op": "increment",
          "value": "1"
        },
        {
          "id": "go_back",
          "type": "api",
          "action": "press_back"
        },
        {
          "id": "clear_notify",
          "type": "set_var",
          "var": "notify",
          "value": ""
        }
      ]
    },
    {
      "id": "summary",
      "type": "ai_summary",
      "prompt": "微信托管任务已结束。\n托管时长：${input.duration}分钟\nAI角色：${input.role}\n共自动回复：${_reply_count}条消息\n\n请生成简洁报告。",
      "output": "result"
    }
  ]
}